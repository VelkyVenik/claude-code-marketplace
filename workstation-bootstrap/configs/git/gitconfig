# Git Configuration
# Deployed by workstation-bootstrap plugin
# Placeholders __NAME__, __EMAIL__, and __SIGNING_KEY_PATH__ are replaced during setup

[user]
    name = __NAME__
    email = __EMAIL__
    signingkey = __SIGNING_KEY_PATH__

[gpg]
    format = ssh

[gpg "ssh"]
    program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[commit]
    gpgsign = true

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[pull]
    rebase = true

[core]
    editor = vim
    autocrlf = input

[diff]
    colorMoved = default

[merge]
    conflictstyle = diff3

[rerere]
    enabled = true
